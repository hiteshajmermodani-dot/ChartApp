<Application x:Class="SampleApplicationChartApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />

            <!-- Circular dotted spinning progress style -->
            <Style x:Key="CircularProgressStyle" TargetType="ProgressBar">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ProgressBar">
                            <Viewbox Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                                <Canvas Width="40" Height="40" RenderTransformOrigin="0.5,0.5">
                                    <Canvas.RenderTransform>
                                        <RotateTransform x:Name="SpinTransform" Angle="0" />
                                    </Canvas.RenderTransform>
                                    <Canvas.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetName="SpinTransform"
                                                           Storyboard.TargetProperty="Angle"
                                                           From="0" To="360"
                                                           Duration="0:0:1" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Canvas.Triggers>
                                    <!-- 8 dots in a circle with fading opacity -->
                                    <Ellipse Width="5" Height="5" Fill="#FF555555" Canvas.Left="17.5" Canvas.Top="0" Opacity="1.0"/>
                                    <Ellipse Width="5" Height="5" Fill="#FF555555" Canvas.Left="28.5" Canvas.Top="4.5" Opacity="0.875"/>
                                    <Ellipse Width="5" Height="5" Fill="#FF555555" Canvas.Left="33" Canvas.Top="17.5" Opacity="0.75"/>
                                    <Ellipse Width="5" Height="5" Fill="#FF555555" Canvas.Left="28.5" Canvas.Top="30.5" Opacity="0.625"/>
                                    <Ellipse Width="5" Height="5" Fill="#FF555555" Canvas.Left="17.5" Canvas.Top="35" Opacity="0.5"/>
                                    <Ellipse Width="5" Height="5" Fill="#FF555555" Canvas.Left="4.5" Canvas.Top="30.5" Opacity="0.375"/>
                                    <Ellipse Width="5" Height="5" Fill="#FF555555" Canvas.Left="0" Canvas.Top="17.5" Opacity="0.25"/>
                                    <Ellipse Width="5" Height="5" Fill="#FF555555" Canvas.Left="4.5" Canvas.Top="4.5" Opacity="0.125"/>
                                </Canvas>
                            </Viewbox>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
