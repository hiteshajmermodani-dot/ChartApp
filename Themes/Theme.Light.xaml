<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
     <!-- Light Theme Colors -->
    <Color x:Key="ChartBackgroundColor">#FFFFFFFF</Color>
    <Color x:Key="ChartAxisColor">#FF222222</Color>
    <Color x:Key="ChartGridColor">#FFCCCCCC</Color>
    <SolidColorBrush x:Key="ChartBackgroundBrush" Color="{StaticResource ChartBackgroundColor}" />
    <SolidColorBrush x:Key="ChartAxisBrush" Color="{StaticResource ChartAxisColor}" />
    <SolidColorBrush x:Key="ChartGridBrush" Color="{StaticResource ChartGridColor}" />
</ResourceDictionary>