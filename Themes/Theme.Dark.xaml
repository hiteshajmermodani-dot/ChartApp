<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
     <!-- Dark Theme Colors -->
    <Color x:Key="ChartBackgroundColor">#FF232323</Color>
    <Color x:Key="ChartAxisColor">#FFEEEEEE</Color>
    <Color x:Key="ChartGridColor">#FF444444</Color>
    <SolidColorBrush x:Key="ChartBackgroundBrush" Color="{StaticResource ChartBackgroundColor}" />
    <SolidColorBrush x:Key="ChartAxisBrush" Color="{StaticResource ChartAxisColor}" />
    <SolidColorBrush x:Key="ChartGridBrush" Color="{StaticResource ChartGridColor}" />
</ResourceDictionary>
