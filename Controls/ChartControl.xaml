<UserControl x:Class="ChartApp.Controls.ChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ChartBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Chart Area (clipped so zoom/pan never overflows into toolbar or legend) -->
        <Grid Grid.Row="0" ClipToBounds="True">
            <Grid x:Name="PART_PlotArea" Margin="5,10,10,30" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Canvas x:Name="PART_Canvas"
                            Grid.Row="0" Grid.Column="0"
                            Background="{DynamicResource ChartBackgroundBrush}"
                            IsHitTestVisible="True"
                            IsManipulationEnabled="True"
                            RenderTransformOrigin="0.0,0.0">
                        <Canvas.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1"/>
                                <TranslateTransform x:Name="PanTransform" X="0" Y="0"/>
                            </TransformGroup>
                        </Canvas.RenderTransform>
                    </Canvas>

                    <!-- Vertical Scrollbar (inside plot area, appears when zoomed vertically) -->
                    <ScrollBar x:Name="PART_VerticalScrollBar"
                               Grid.Row="0"
                               Grid.Column="1"
                               Orientation="Vertical"
                               Visibility="Collapsed"
                               Scroll="VerticalScrollBar_Scroll" />

                    <!-- Horizontal Scrollbar (inside plot area, appears when zoomed horizontally) -->
                    <ScrollBar x:Name="PART_HorizontalScrollBar"
                               Grid.Row="1"
                               Grid.Column="0"
                               Orientation="Horizontal"
                               Visibility="Collapsed"
                               Scroll="HorizontalScrollBar_Scroll" />
                </Grid>
            </Grid>

            <!-- Y-Axis Interactive Area -->
            <Border x:Name="PART_YAxisArea"
                    Width="5"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Margin="0,10,0,90"
                    Background="Transparent"
                    Cursor="SizeNS"
                    MouseLeftButtonDown="YAxis_MouseLeftButtonDown"
                    MouseMove="YAxis_MouseMove"
                    MouseLeftButtonUp="YAxis_MouseLeftButtonUp" />

            <!-- X-Axis Interactive Area -->
            <Border x:Name="PART_XAxisArea"
                    Height="30"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Bottom"
                    Margin="5,0,10,0"
                    Background="Transparent"
                    Cursor="SizeWE"
                    MouseLeftButtonDown="XAxis_MouseLeftButtonDown"
                    MouseMove="XAxis_MouseMove"
                    MouseLeftButtonUp="XAxis_MouseLeftButtonUp" />

            <!-- Axes Canvas — no zoom/pan transform, axes are drawn here so they stay visually constant after zoom -->
            <Canvas x:Name="PART_AxesCanvas"
                    IsHitTestVisible="False" />

            <Canvas x:Name="PART_Overlay"
                    Margin="5,10,10,30"
                    IsHitTestVisible="False"
                    ClipToBounds="True">

                <Rectangle x:Name="ZoomRectangle"
                           Visibility="Collapsed" />

            </Canvas>

            <!-- 3D Surface Viewport — shown only when ChartType = Surface3DPlot -->
            <Viewport3D x:Name="PART_Viewport3D"
                        Visibility="Collapsed"
                        ClipToBounds="True" />

            <!-- Transparent hit-test layer over 3D viewport — captures mouse from anywhere in the plot area -->
            <Rectangle x:Name="PART_3DMouseLayer"
                       Visibility="Collapsed"
                       Fill="Transparent"
                       Cursor="SizeAll" />

        </Grid>

        <!-- Legend -->
        <StackPanel x:Name="PART_Legend"
                    Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="5,0,5,5"/>
    </Grid>

    <UserControl.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Save as Screenshot..." Click="ContextMenu_SaveScreenshot_Click" />
            <MenuItem Header="Copy Image to Clipboard" Click="ContextMenu_CopyImage_Click" />
            <MenuItem Header="Copy X/Y Values to Clipboard" Click="ContextMenu_CopyXY_Click" />
        </ContextMenu>
    </UserControl.ContextMenu>
</UserControl>